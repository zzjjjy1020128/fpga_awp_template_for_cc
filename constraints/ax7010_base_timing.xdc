#==============================================================================
# ax7010_base_timing.xdc — AX7010 基座时序约束
# 目标: xc7z010clg400-1 (Zynq-7000)
# 基座: HW_BASE_AX7010_v1.1
#==============================================================================
# 时钟 FCLK_CLK0 (50 MHz) 由 PS7 IP 自带 XDC 自动创建。
# 独立调试时钟 clk_debug_50m 由板载晶振提供，为 System ILA 提供时钟。
# 所有数据通路均在芯片内部（PS ↔ PL AXI 互联）。
#==============================================================================

# 独立调试时钟 — 板载 50 MHz 有源晶振 (Y2, PL U18)
# 与 FCLK_CLK0 频率相同(50 MHz)但独立于 PS PLL
create_clock -period 20.000 -name clk_debug_50m [get_ports clk_debug_50m]
