# <type>(<scope>): <subject>
# |      |        |
# |      |        +-- 简短描述（中文或英文，< 50 字符）
# |      +-- 模板（可 cherry-pick 回 master）: awp | conf
# |      +-- 项目（仅 exp 分支）: session | rtl | tb | constraints | vivado | docs | board
# +-- 变更类型: feat | fix | refactor | docs | chore | test
#
# Task: <task_id>
# Session: <session_id>
# Validation: <当前通过的验证级别>
#
# <详细说明>
#
# 示例:
# feat(rtl): implement axis_shift_2d module
#
# Task: TASK-E001-001
# Session: SESS-E001-OR-001
# Validation: L1 pass
