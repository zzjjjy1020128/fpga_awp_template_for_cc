{
  "note": "Project-local Claude settings. Do not store secrets here.",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/AGENT_WORK_SPACE_FOR_CLAUDE/fpga_awp_template/scripts/session_skeleton.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python D:/AGENT_WORK_SPACE_FOR_CLAUDE/fpga_awp_template/scripts/validate_awp.py --guard session-start",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/AGENT_WORK_SPACE_FOR_CLAUDE/fpga_awp_template/scripts/validate_awp.py --guard pre-spawn",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/AGENT_WORK_SPACE_FOR_CLAUDE/fpga_awp_template/scripts/validate_awp.py --guard pre-stop",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
