{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": ".awp/schemas/workspace_manifest.schema.json",
  "title": "Workspace Manifest Schema",
  "description": "FPGA-AWP workspace manifest 的基本结构校验",
  "type": "object",
  "required": ["project", "directories", "protected_paths", "validation_levels", "default_agent_policy"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name", "domain", "template_version"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "domain": { "type": "string" },
        "template_version": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "domain": {
      "type": "string",
      "description": "项目领域"
    },
    "template_version": {
      "type": "string",
      "description": "模板版本号"
    },
    "directories": {
      "type": "object",
      "description": "目录定义映射"
    },
    "protected_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation_levels": {
      "type": "object",
      "required": ["L0", "L1a", "L1b", "L1c", "L2", "L3", "L4", "L5", "L6", "L7"],
      "properties": {
        "L0": { "type": "string" },
        "L1a": { "type": "string" },
        "L1b": { "type": "string" },
        "L1c": { "type": "string" },
        "L2": { "type": "string" },
        "L3": { "type": "string" },
        "L4": { "type": "string" },
        "L5": { "type": "string" },
        "L6": { "type": "string" },
        "L7": { "type": "string" }
      }
    },
    "platforms": {
      "type": "array",
      "description": "已冻结的硬件基座清单，每个基座对应一个板卡/器件",
      "items": {
        "type": "object",
        "required": ["id", "manifest", "status"],
        "properties": {
          "id": { "type": "string", "description": "基座唯一标识，如 HW_BASE_ZCU102_v1.0" },
          "manifest": { "type": "string", "description": "平台清单 YAML 路径，如 .awp/platform/hw_base_zcu102_v1.0.yaml" },
          "status": { "type": "string", "enum": ["frozen", "candidate", "revised"] },
          "frozen_date": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "default_agent_policy": {
      "type": "object",
      "required": ["language", "record_all_sessions", "require_handoff"],
      "properties": {
        "language": { "type": "string" },
        "code_identifiers": { "type": "string" },
        "protocol_names": { "type": "string" },
        "record_all_sessions": { "type": "boolean" },
        "require_handoff": { "type": "boolean", "description": "是否要求 session 结束时创建 handoff（当后续 task 未完成时）" },
        "require_review_for_rtl": { "type": "boolean" },
        "require_board_validation_for_bitstream": { "type": "boolean" }
      }
    }
  }
}
